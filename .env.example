# Database
POSTGRES_DB=teamflow_db
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=your_password_here

# JWT
JWT_SECRET_KEY=your_secret_key_minimum_32_characters_here
JWT_ISSUER=TeamFlow
JWT_AUDIENCE=TeamFlowUsers
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string_here
AZURE_STORAGE_CONTAINER_NAME=teamflow-files