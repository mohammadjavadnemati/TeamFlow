{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=teamflow_db;Username=teamflow;Password=teamflow_pass"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_VERY_LONG_SECRET_KEY_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "TeamFlow",
    "Audience": "TeamFlowUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
